    {
      "version": "1.0.2",
      "releaseDate": "2026-07-12",
      "title": "\u4fee\u590d\u4e3b\u7a0b\u5e8f\u56fe\u6807\u663e\u793a",
      "notes": [
        "\u4fee\u590d\u5b89\u88c5\u5305\u751f\u6210\u540e\u4e3b\u7a0b\u5e8f\u4ecd\u663e\u793a Electron \u9ed8\u8ba4\u56fe\u6807\u7684\u95ee\u9898\uff0c\u684c\u9762\u5feb\u6377\u65b9\u5f0f\u548c\u5f00\u59cb\u83dc\u5355\u56fe\u6807\u4f1a\u8ddf\u968f TEMU \u56fe\u6807\u3002",
        "\u7edf\u4e00 Windows \u5b89\u88c5\u5305\u3001\u5378\u8f7d\u5668\u548c\u4e3b\u7a0b\u5e8f\u7684\u56fe\u6807\u914d\u7f6e\uff0c\u907f\u514d\u4e0d\u540c\u5165\u53e3\u663e\u793a\u4e0d\u4e00\u81f4\u3002"
      ]
    },
    {
      "version": "1.0.1",
      "releaseDate": "2026-07-12",
      "title": "\u8f6f\u4ef6\u66f4\u65b0\u548c\u4e3b\u9898\u63d0\u793a\u4f18\u5316",
      "notes": [
        "\u4fee\u590d\u66f4\u65b0\u670d\u52a1\u521d\u59cb\u5316\u987a\u5e8f\u5f02\u5e38\uff0c\u907f\u514d\u8f6f\u4ef6\u542f\u52a8\u65f6\u51fa\u73b0\u4e3b\u8fdb\u7a0b JavaScript \u9519\u8bef\u3002",
        "\u786e\u8ba4\u4fe1\u606f\u6846\u548c\u63d0\u793a\u6846\u7684 warning \u6837\u5f0f\u6539\u4e3a\u8ddf\u968f\u5168\u5c40\u4e3b\u9898\u914d\u8272\uff0c\u53ea\u4fdd\u7559\u5371\u9669\u64cd\u4f5c\u4f7f\u7528\u7ea2\u8272\u3002",
        "\u4f18\u5316\u786e\u8ba4\u6846\u515c\u5e95\u4e3b\u9898\u8ba1\u7b97\uff0c\u6309\u5f53\u524d\u4e3b\u9898\u8272\u81ea\u52a8\u751f\u6210\u80cc\u666f\u3001\u8fb9\u6846\u548c\u6309\u94ae\u5bf9\u6bd4\u8272\u3002",
        "\u5b8c\u5584\u8f6f\u4ef6\u66f4\u65b0\u53d1\u5e03\u6d41\u7a0b\uff0c\u652f\u6301\u751f\u6210\u5e76\u4e0a\u4f20 latest.yml\u3001\u5b89\u88c5\u5305\u548c\u7248\u672c\u66f4\u65b0\u8bb0\u5f55\u3002"
      ]
    },
    {
      "version": "1.0.0",
      "releaseDate": "2026-07-12",
      "title": "\u65b0\u589e\u8f6f\u4ef6\u66f4\u65b0\u80fd\u529b",
      "notes": [
        "\u4e3b\u7a97\u53e3\u65b0\u589e\u68c0\u67e5\u66f4\u65b0\u5165\u53e3\uff0c\u652f\u6301\u53d1\u73b0\u65b0\u7248\u672c\u3001\u4e0b\u8f7d\u8fdb\u5ea6\u548c\u91cd\u542f\u5b89\u88c5\u3002",
        "\u5168\u5c40\u914d\u7f6e\u7684\u66f4\u65b0\u8bbe\u7f6e\u5df2\u63a5\u5165\u66f4\u65b0\u670d\u52a1\uff0c\u53ef\u63a7\u5236\u542f\u52a8\u68c0\u67e5\u3001\u66f4\u65b0\u901a\u9053\u548c\u5dee\u5f02\u66f4\u65b0\u3002",
        "\u65b0\u589e\u66f4\u65b0\u5305\u53d1\u5e03\u811a\u672c\uff0c\u53ef\u5c06\u5b89\u88c5\u5305\u3001latest.yml \u548c\u7248\u672c\u8bb0\u5f55\u4e0a\u4f20\u5230 COS \u66f4\u65b0\u76ee\u5f55\u3002"
      ]
    }
  ]
}
