  "items": [
    {
      "version": "1.0.7",
      "releaseDate": "2026-07-19",
      "title": "\u63a8\u5e7f\u5927\u5e08\u5e97\u94fa\u6570\u636e\u4e0e\u5217\u8868\u4f53\u9a8c\u4f18\u5316",
      "notes": [
        "\u5e97\u94fa\u6570\u636e\u65b0\u589e\u63a8\u5e7f\u5546\u54c1\u6570\u91cf\u5c55\u793a\uff0c\u6309\u7f8e\u56fd\u3001\u6b27\u533a\u3001\u5168\u7403\u5206\u522b\u663e\u793a queryReports \u8fd4\u56de\u7684\u63a8\u5e7f\u5546\u54c1\u6570\u3002",
        "\u4fee\u590d\u5e97\u94fa\u6570\u636e\u7a7a\u5217\u8868\u6a2a\u5411\u6eda\u52a8\u6761\u6b8b\u7559\u95ee\u9898\uff0c\u7a7a\u72b6\u6001\u4f1a\u81ea\u9002\u5e94\u586b\u6ee1\u5230\u5e95\u90e8\u3002",
        "\u4f18\u5316\u65b0\u5efa\u63a8\u5e7f\u5546\u54c1\u5217\u8868\u81ea\u9002\u5e94\u9ad8\u5ea6\uff0c\u7a7a\u5217\u8868\u548c\u6570\u636e\u5217\u8868\u90fd\u80fd\u8ddf\u968f\u7a97\u53e3\u6491\u5230\u5e95\u90e8\u3002",
        "\u52a0\u5bbd\u5e97\u94fa\u6570\u636e\u548c\u63a8\u5e7f\u660e\u7ec6\u7684\u6570\u636e\u65f6\u95f4\u9009\u62e9\u5668\uff0c\u51cf\u5c11\u65e5\u671f\u6587\u672c\u88ab\u6324\u538b\u7684\u95ee\u9898\u3002"
      ]
    },
    {
      "version": "1.0.6",
      "releaseDate": "2026-07-19",
      "title": "\u63a8\u5e7f\u5927\u5e08\u529f\u80fd\u4f18\u5316",
      "notes": [
        "\u63a8\u5e7f\u5927\u5e08\u65b0\u5efa\u63a8\u5e7f\u652f\u6301\u6309\u9884\u4f30\u6263\u8d39\u548c\u9884\u4f30\u5360\u6bd4\u6279\u91cf\u6362\u7b97\u81ea\u5b9a\u4e49 ROAS\uff0c\u4e00\u952e\u8bbe\u7f6e\u4f1a\u6309\u6bcf\u4e2a\u5546\u54c1\u4f9b\u8d27\u4ef7\u8ba1\u7b97\u540e\u518d\u63d0\u4ea4\u3002",
        "\u63a8\u5e7f\u5927\u5e08\u65b0\u5efa\u63a8\u5e7f\u548c\u63a8\u5e7f\u660e\u7ec6\u7684\u5546\u54c1\u56fe\u7247\u6539\u4e3a\u7f29\u7565\u56fe\u52a0\u8f7d\uff0c\u70b9\u51fb\u56fe\u7247\u53ef\u67e5\u770b\u5b8c\u6574\u539f\u56fe\uff0c\u63d0\u5347\u5927\u6279\u91cf\u5546\u54c1\u5217\u8868\u52a0\u8f7d\u901f\u5ea6\u3002",
        "\u63a8\u5e7f\u660e\u7ec6\u548c\u65b0\u5efa\u63a8\u5e7f\u7684\u5168\u90e8\u64cd\u4f5c\u4fdd\u6301\u53ea\u5904\u7406\u5f53\u524d\u641c\u7d22\u7b5b\u9009\u540e\u7684\u5217\u8868\u7ed3\u679c\uff0c\u907f\u514d\u8bef\u64cd\u4f5c\u672a\u663e\u793a\u7684\u6570\u636e\u3002",
        "\u4f18\u5316\u63a8\u5e7f\u5927\u5e08\u6279\u91cf\u8bbe\u7f6e\u63d0\u793a\u8bf4\u660e\u548c\u4e91\u7aef\u540c\u6b65\u7f13\u5b58\uff0c\u4fdd\u7559\u5e97\u94fa\u3001\u5730\u533a\u3001\u7b5b\u9009\u548c\u6279\u91cf\u8bbe\u7f6e\u914d\u7f6e\u3002"
      ]
    },
    {
      "version": "1.0.5",
      "releaseDate": "2026-07-18",
      "title": "\u767b\u5f55\u4fdd\u6301\u4e0e\u5b58\u50a8\u7d20\u6750\u8def\u5f84\u4fee\u590d",
      "notes": [
        "\u4f18\u5316\u8f6f\u4ef6\u8bb0\u4f4f\u767b\u5f55\u903b\u8f91\uff0c\u5f00\u542f\u8bb0\u4f4f\u767b\u5f55\u540e\u91cd\u542f\u8f6f\u4ef6\u4f1a\u6062\u590d\u767b\u5f55\u4f1a\u8bdd\uff0c\u51cf\u5c11\u91cd\u590d\u8f93\u5165\u8d26\u53f7\u5bc6\u7801\u3002",
        "\u7b80\u5316\u9000\u51fa\u548c\u5173\u95ed\u8f6f\u4ef6\u786e\u8ba4\u6846\uff0c\u53bb\u6389\u591a\u4f59\u63d0\u793a\u5185\u5bb9\uff0c\u53ea\u4fdd\u7559\u786e\u8ba4\u548c\u53d6\u6d88\u64cd\u4f5c\u3002",
        "\u4fee\u590d POD \u5999\u624b TEMU \u7248\u548c\u901a\u7528\u7248\u7684\u5b58\u50a8\u7d20\u6750\u4e0a\u4f20\u8def\u5f84\uff0c\u56fe\u7247\u4e0a\u4f20\u548c\u6279\u91cf AI \u6807\u9898\u8bc6\u56fe\u4e0d\u518d\u8ffd\u52a0\u7528\u6237\u540d\u6216 users/userKey \u8def\u5f84\u5c42\u3002",
        "\u65e7\u7684\u5b58\u50a8\u7d20\u6750\u8def\u5f84\u7f13\u5b58\u4f1a\u6309\u5931\u6548\u5904\u7406\uff0c\u4e0d\u518d\u7ee7\u7eed\u5339\u914d\u65e7\u7528\u6237\u8def\u5f84\uff0c\u907f\u514d\u65b0\u4e0a\u4f20\u56fe\u7247\u4ecd\u663e\u793a\u65e7\u8def\u5f84\u3002",
        "\u6279\u91cf AI \u6807\u9898\u7f13\u5b58\u5347\u7ea7\u4e3a\u65b0\u7684\u7d20\u6750\u6839\u8def\u5f84\u89c4\u5219\uff0c\u65e7\u7f13\u5b58\u4e0d\u4f1a\u6df7\u5165\u65b0\u7ed3\u679c\u3002"
      ]
    },
    {
      "version": "1.0.4",
      "releaseDate": "2026-07-16",
      "title": "POD\u4e0a\u8d27\u8868\u683c\u5b58\u50a8\u548c\u5bfc\u51fa\u4fee\u590d",
      "notes": [
        "POD\u5999\u624b TEMU \u7248\u548c\u901a\u7528\u7248\u56fe\u7247\u4e0a\u4f20\u3001\u6279\u91cf AI \u6807\u9898\u8bc6\u56fe\u4f1a\u6309\u5b58\u50a8\u7d20\u6750\u9009\u62e9\u4e0a\u4f20\u5230\u817e\u8baf COS \u6216 Cloudflare R2\u3002",
        "\u817e\u8baf COS \u6216 Cloudflare R2 \u914d\u7f6e\u4e0d\u5b8c\u6574\u65f6\u76f4\u63a5\u63d0\u793a\uff0c\u4e0d\u518d\u56de\u9000\u5230\u65e7\u9ed8\u8ba4\u5b58\u50a8\u6876\uff0c\u907f\u514d\u65b0\u7d20\u6750\u4e0a\u4f20\u5230\u9519\u8bef\u8def\u5f84\u3002",
        "\u6279\u91cf AI \u751f\u6210\u6807\u9898\u652f\u6301 30 \u5230 300 \u7684\u6807\u9898\u957f\u5ea6\u8303\u56f4\uff0c\u5e76\u5c06 AI \u6807\u9898\u8bc6\u56fe\u4e0a\u4f20\u76ee\u5f55\u8c03\u6574\u4e3a AI\u6807\u9898\u8bc6\u56fe_\u5999\u624b\u7248\u3002",
        "\u4fee\u590d POD \u4e0a\u8d27\u8868\u683c\u5bfc\u51fa\u5b57\u6bb5\u95ee\u9898\uff0c\u8865\u9f50 TEMU \u7248\u5efa\u8bae\u552e\u4ef7\uff0c\u5e76\u4f18\u5316\u8be6\u60c5\u56fe\u548c\u4ea7\u54c1\u63cf\u8ff0\u56fe\u7247\u94fe\u63a5\u5bfc\u51fa\u6620\u5c04\u3002",
        "POD\u5999\u624b TEMU \u7248\u548c\u901a\u7528\u7248\u7684\u6279\u91cf AI \u6807\u9898\u5f39\u7a97\u6539\u4e3a\u5171\u4eab\u72b6\u6001\u6a21\u5757\uff0cTEMU \u7248\u4fdd\u6301\u4e2d\u82f1\u53cc\u6807\u9898\uff0c\u901a\u7528\u7248\u4fdd\u7559\u8f93\u51fa\u8bed\u8a00\u9009\u62e9\u3002",
        "\u4f18\u5316\u6279\u91cf AI \u6807\u9898\u4f7f\u7528\u7f13\u5b58\u7684\u6027\u80fd\uff0c\u91cd\u590d\u5546\u54c1\u53ef\u5728\u56fe\u7247\u538b\u7f29\u548c\u4e0a\u4f20\u524d\u547d\u4e2d\u7f13\u5b58\uff0c\u51cf\u5c11\u591a\u7ebf\u7a0b\u6279\u91cf\u5904\u7406\u65f6\u7684 CPU \u538b\u529b\u3002",
        "\u4f18\u5316\u63a8\u5e7f\u5927\u5e08-\u65b0\u7684\u529f\u80fd\u5207\u6362\u9875\u9762\u5e03\u5c40\uff0c\u529f\u80fd\u4e2d\u5fc3\u5165\u53e3\u5207\u6362\u66f4\u7a33\u5b9a\u3002"
      ]
    },
    {
      "version": "1.0.3",
      "releaseDate": "2026-07-14",
      "title": "PSD\u667a\u80fd\u5957\u56fe\u7a33\u5b9a\u6027\u4f18\u5316",
      "notes": [
        "\u4f18\u5316 PSD \u667a\u80fd\u5957\u56fe\u7684 Photopea \u5f15\u64ce\u94fe\u8def\uff0c\u62c6\u5206\u672c\u5730\u6587\u4ef6\u670d\u52a1\u3001\u56fe\u7247\u5904\u7406\u3001\u811a\u672c\u6784\u5efa\u3001\u6d88\u606f\u89e3\u6790\u548c\u8c03\u8bd5\u65e5\u5fd7\u6a21\u5757\uff0c\u964d\u4f4e\u4e3b\u6e32\u67d3\u5668\u590d\u6742\u5ea6\u3002",
        "\u4f18\u5316\u5957\u56fe\u4efb\u52a1\u8fdb\u5ea6\u4e0e\u65e5\u5fd7\u5904\u7406\uff0c\u51cf\u5c11\u9ad8\u9891\u8fdb\u5ea6\u65e5\u5fd7\u9020\u6210\u7684\u9875\u9762\u5361\u987f\uff0c\u5e76\u9650\u5236\u65e5\u5fd7\u4fdd\u7559\u6570\u91cf\u3002",
        "\u4f18\u5316\u7d20\u6750\u56fe\u7247\u76ee\u5f55\u8bfb\u53d6\u6027\u80fd\uff0c\u9012\u5f52\u6536\u96c6\u540e\u7edf\u4e00\u6392\u5e8f\uff0c\u6279\u91cf\u7d20\u6750\u573a\u666f\u66f4\u7a33\u5b9a\u3002",
        "\u52a0\u5f3a Photopea \u6d88\u606f\u548c\u5bfc\u51fa\u56fe\u7247\u5904\u7406\u8fb9\u754c\uff0c\u63d0\u5347\u667a\u80fd\u5bf9\u8c61\u66ff\u6362\u3001\u5bfc\u51fa\u548c\u5f02\u5e38\u63d0\u793a\u7684\u7a33\u5b9a\u6027\u3002"
      ]
    },
    {
      "version": "1.0.2",
      "releaseDate": "2026-07-12",
      "title": "\u4fee\u590d\u4e3b\u7a0b\u5e8f\u56fe\u6807\u663e\u793a",
      "notes": [
        "\u4fee\u590d\u5b89\u88c5\u5305\u751f\u6210\u540e\u4e3b\u7a0b\u5e8f\u4ecd\u663e\u793a Electron \u9ed8\u8ba4\u56fe\u6807\u7684\u95ee\u9898\uff0c\u684c\u9762\u5feb\u6377\u65b9\u5f0f\u548c\u5f00\u59cb\u83dc\u5355\u56fe\u6807\u4f1a\u8ddf\u968f TEMU \u56fe\u6807\u3002",
        "\u7edf\u4e00 Windows \u5b89\u88c5\u5305\u3001\u5378\u8f7d\u5668\u548c\u4e3b\u7a0b\u5e8f\u7684\u56fe\u6807\u914d\u7f6e\uff0c\u907f\u514d\u4e0d\u540c\u5165\u53e3\u663e\u793a\u4e0d\u4e00\u81f4\u3002"
      ]
    },
    {
      "version": "1.0.1",
      "releaseDate": "2026-07-12",
      "title": "\u8f6f\u4ef6\u66f4\u65b0\u548c\u4e3b\u9898\u63d0\u793a\u4f18\u5316",
      "notes": [
        "\u4fee\u590d\u66f4\u65b0\u670d\u52a1\u521d\u59cb\u5316\u987a\u5e8f\u5f02\u5e38\uff0c\u907f\u514d\u8f6f\u4ef6\u542f\u52a8\u65f6\u51fa\u73b0\u4e3b\u8fdb\u7a0b JavaScript \u9519\u8bef\u3002",
        "\u786e\u8ba4\u4fe1\u606f\u6846\u548c\u63d0\u793a\u6846\u7684 warning \u6837\u5f0f\u6539\u4e3a\u8ddf\u968f\u5168\u5c40\u4e3b\u9898\u914d\u8272\uff0c\u53ea\u4fdd\u7559\u5371\u9669\u64cd\u4f5c\u4f7f\u7528\u7ea2\u8272\u3002",
        "\u4f18\u5316\u786e\u8ba4\u6846\u515c\u5e95\u4e3b\u9898\u8ba1\u7b97\uff0c\u6309\u5f53\u524d\u4e3b\u9898\u8272\u81ea\u52a8\u751f\u6210\u80cc\u666f\u3001\u8fb9\u6846\u548c\u6309\u94ae\u5bf9\u6bd4\u8272\u3002",
        "\u5b8c\u5584\u8f6f\u4ef6\u66f4\u65b0\u53d1\u5e03\u6d41\u7a0b\uff0c\u652f\u6301\u751f\u6210\u5e76\u4e0a\u4f20 latest.yml\u3001\u5b89\u88c5\u5305\u548c\u7248\u672c\u66f4\u65b0\u8bb0\u5f55\u3002"
      ]
    },
    {
      "version": "1.0.0",
      "releaseDate": "2026-07-12",
      "title": "\u65b0\u589e\u8f6f\u4ef6\u66f4\u65b0\u80fd\u529b",
      "notes": [
        "\u4e3b\u7a97\u53e3\u65b0\u589e\u68c0\u67e5\u66f4\u65b0\u5165\u53e3\uff0c\u652f\u6301\u53d1\u73b0\u65b0\u7248\u672c\u3001\u4e0b\u8f7d\u8fdb\u5ea6\u548c\u91cd\u542f\u5b89\u88c5\u3002",
        "\u5168\u5c40\u914d\u7f6e\u7684\u66f4\u65b0\u8bbe\u7f6e\u5df2\u63a5\u5165\u66f4\u65b0\u670d\u52a1\uff0c\u53ef\u63a7\u5236\u542f\u52a8\u68c0\u67e5\u3001\u66f4\u65b0\u901a\u9053\u548c\u5dee\u5f02\u66f4\u65b0\u3002",
        "\u65b0\u589e\u66f4\u65b0\u5305\u53d1\u5e03\u811a\u672c\uff0c\u53ef\u5c06\u5b89\u88c5\u5305\u3001latest.yml \u548c\u7248\u672c\u8bb0\u5f55\u4e0a\u4f20\u5230 COS \u66f4\u65b0\u76ee\u5f55\u3002"
      ]
    }
  ]
}
